# ── LinkedIn ──────────────────────────────────
USERNAME=your_linkedin_email@gmail.com
PASSWORD=your_linkedin_password
GITHUB_URL=https://github.com/yourusername

# ── AI MODEL SELECTOR 🆕 ──────────────────────
# Choose your AI model:
#   gemini  → Google Gemini 2.5 Pro  (default, recommended)
#   gpt-4o  → OpenAI GPT-4o
AI_MODEL=gemini

# ── API Keys ──────────────────────────────────
# Add the key that matches your AI_MODEL above.
# If AI_MODEL=gemini  → fill GOOGLE_API_KEY
# If AI_MODEL=gpt-4o  → fill OPENAI_API_KEY
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Multi-Account LinkedIn (optional) ─────────
LINKEDIN_ACCOUNTS=account1@email.com,account2@email.com
LINKEDIN_PASSWORDS=password1,password2

# ── Facebook (optional) ───────────────────────
FB_USERNAME=your_facebook_email
FB_PASSWORD=your_facebook_password

# ── Instagram (optional) ──────────────────────
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ── Telegram (optional) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email / Gmail (optional) ──────────────────
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=receiver@example.com
REMINDER_RECIPIENTS=you@gmail.com

# ── Voice — ElevenLabs (optional) ────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Voice-to-Text ─────────────────────────────
TRANSCRIPTION_ENGINE=whisper

# ── Feature Flags ─────────────────────────────
CONNECTION_TRACKER_ENABLED=true
